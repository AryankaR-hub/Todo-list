# --- Dependencies ---
# Never upload this folder; it's huge and can be recreated with 'npm install'
node_modules/

# --- Security ---
# This contains your MONGO_URI and API keys. 
# Keeping this private is the #1 rule of backend dev.
.env

# --- Environment Specific ---
# Local environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs ---
# Error logs generated by npm or yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# --- System Files ---
# Mac and Windows specific files that clutter the repo
.DS_Store
Thumbs.db
desktop.ini

# --- IDE/Editor Settings ---
# Folders created by VS Code, IntelliJ, etc.
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
